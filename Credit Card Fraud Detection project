      "source": [
        "Handling Imbalanced Data :(Under-Sampling)\n"
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "legit = df[df[\"Class\"] == 0]\n",
        "fraud = df[df[\"Class\"] == 1]\n",
        "\n",
        "legit_sample = legit.sample(n=len(fraud), random_state=42)\n",
        "df_under = pd.concat([legit_sample, fraud], axis=0).sample(frac=1, random_state=42)\n",
        "\n",
        "X_u = df_under.drop(columns=\"Class\")\n",
        "y_u = df_under[\"Class\"]\n",
        "\n",
        "X_train_u, X_test_u, y_train_u, y_test_u = train_test_split(\n",
        "    X_u, y_u, test_size=0.2, stratify=y_u, random_state=42\n",
        ")\n",
        "\n",
        "log_reg_under = Pipeline(steps=[\n",
        "    (\"scaler\", StandardScaler()),\n",
        "    (\"clf\", LogisticRegression(max_iter=2000))\n",
        "])\n",
        "\n",
        "log_reg_under.fit(X_train_u, y_train_u)\n",
        "\n",
        "y_pred_u = log_reg_under.predict(X_test_u)\n",
        "y_proba_u = log_reg_under.predict_proba(X_test_u)[:, 1]\n",
        "\n",
        "print(\"\\n=== Logistic Regression (Under-sampling) ===\")\n",
        "print(\"Accuracy:\", accuracy_score(y_test_u, y_pred_u))\n",
        "print(\"Confusion matrix:\\n\", confusion_matrix(y_test_u, y_pred_u))\n",
        "print(\"Report:\\n\", classification_report(y_test_u, y_pred_u, digits=4))\n",
        "print(\"ROC-AUC:\", roc_auc_score(y_test_u, y_proba_u))\n",
        "print(\"PR-AUC:\", average_precision_score(y_test_u, y_proba_u))"
